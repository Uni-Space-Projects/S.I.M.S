{
  "name": "sims",
  "version": "1.0.0",
  "private": true,
  "description": "SIMS - Sistema de Gestión de Insumos Médicos",
  "engines": {
    "node": ">=24"
  },
  //Comandos para ejecutar el proyecto, hay que revisar.
  "scripts": {
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "npm run start:dev --prefix backend",
    "start:debug": "npm start --debug --watch",
    "dev": "concurrently -c \"cyan.bold,magenta.bold\" -n \"NEXT,NEST\" \"npm run dev:frontend\" \"npm run dev:backend\""
  },
  //npm install -D concurrently
  "devDependencies": {
    "concurrently": "^8.0.0"
  }
}
