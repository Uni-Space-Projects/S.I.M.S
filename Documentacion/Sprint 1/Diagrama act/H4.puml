H4

@startuml
title act Visualizar y buscar insumos disponibles

|Usuario|
start
:Acceder a la aplicación web;
:Ingresar al catálogo de insumos disponibles;

|Sistema|
:Consultar publicaciones activas;
:Mostrar listado de insumos disponibles;

|Usuario|
if (¿Desea buscar o filtrar?) then (Sí)
  :Ingresar nombre o seleccionar categoría;

  |Sistema|
  :Aplicar criterios de búsqueda;
  :Consultar publicaciones coincidentes;

  if (¿Existen resultados?) then (Sí)
    :Mostrar resultados filtrados;

    |Usuario|
    :Seleccionar insumo del listado;

    |Sistema|
    :Mostrar detalle completo del insumo;
    stop

  else (No)
    :Mostrar mensaje "No hay resultados coincidentes";

    |Usuario|
    if (¿Desea intentar otra búsqueda?) then (Sí)
      :Modificar criterios de búsqueda;

      |Sistema|
      :Aplicar nuevos criterios;
      stop
    else (No)
      :Finalizar búsqueda;
      stop
    endif
  endif

else (No)
  :Seleccionar insumo del listado general;

  |Sistema|
  :Mostrar detalle completo del insumo;
  stop
endif

@enduml