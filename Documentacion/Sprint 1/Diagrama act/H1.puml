H1

@startuml
title act Gestionar acceso del usuario

|Usuario|
start
:Acceder a la aplicación web;

if (¿Tiene cuenta registrada?) then (No)
  :Seleccionar opción "Registrarse";
  :Ingresar datos de registro;

  |Sistema|
  :Validar datos ingresados;

  if (¿Datos válidos y correo disponible?) then (Sí)
    :Crear cuenta de usuario;
    :Guardar usuario en base de datos;
    :Mostrar mensaje de registro exitoso;

    |Usuario|
    :Seleccionar opción "Iniciar sesión";
  else (No)
    :Mostrar errores de validación;

    |Usuario|
    :Corregir datos de registro;
    stop
  endif

else (Sí)
  :Seleccionar opción "Iniciar sesión";
endif

|Usuario|
:Ingresar correo y contraseña;

|Sistema|
:Validar credenciales;

if (¿Credenciales válidas?) then (Sí)
  :Crear sesión de usuario;
  :Redirigir al panel principal;

  |Usuario|
  :Seleccionar opción "Cerrar sesión";

  |Sistema|
  :Invalidar sesión;

  stop

else (No)
  :Mostrar mensaje de credenciales inválidas;

  |Usuario|
  :Reintentar inicio de sesión;
  stop
endif

@enduml