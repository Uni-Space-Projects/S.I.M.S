H3

@startuml
title act Editar o eliminar publicación de insumo médico

|Usuario|
start
:Iniciar sesión;
:Acceder a "Mis publicaciones";
:Seleccionar publicación propia;


  |Usuario|
  if (¿Qué acción desea realizar?) then (Editar)
    :Modificar datos de la publicación;

    |Sistema|
    :Validar datos modificados;

    if (¿Datos válidos?) then (Sí)
      :Guardar cambios en base de datos;
      :Actualizar publicación;
      :Mostrar mensaje de actualización exitosa;
      stop
    else (No)
      :Mostrar errores de validación;

      |Usuario|
      :Corregir datos;
      stop
    endif

  else (Eliminar)
    :Solicitar eliminación de publicación;

    |Sistema|
    :Solicitar confirmación de eliminación;

    |Usuario|
    if (¿Confirma eliminación?) then (Sí)

      |Sistema|
      :Verificar estado de la publicación;

      if (¿Tiene transacción cerrada?) then (Sí)
        :Impedir eliminación definitiva;
        :Ocultar publicación del listado público;
        :Conservar registro histórico;
        :Mostrar mensaje de restricción;
        stop
      else (No)
        :Eliminar publicación;
        :Actualizar listado público;
        :Mostrar mensaje de eliminación exitosa;
        stop
      endif

    else (No)
      :Cancelar operación;

      |Sistema|
      :Mantener publicación sin cambios;
      stop
    endif
  endif


@enduml